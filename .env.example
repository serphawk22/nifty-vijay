# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
# Use the transaction pooler URL (port 6543) on Vercel for serverless compatibility
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# ─── Redis (optional — used for pub/sub in WebSocket server) ──────────────────
# Leave empty or set to Upstash or Railway Redis URL for production
# REDIS_URL="rediss://default:TOKEN@HOST.upstash.io:6379"

# ─── WebSocket Server ─────────────────────────────────────────────────────────
# ⚠️  DO NOT SET THIS IN PRODUCTION (Render/Vercel).
# The WebSocket server runs on the SAME origin as the Next.js app (via server.js).
# Setting this to localhost:3001 will break live the deployment.
# Only uncomment for a fully separate dedicated socket server.
# NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# ─── Zerodha Kite Connect ─────────────────────────────────────────────────────
KITE_API_KEY="your-kite-api-key"
KITE_API_SECRET="your-kite-api-secret"
# Rotates daily — set via /api/kite/callback after each login
KITE_ACCESS_TOKEN="your-kite-access-token"

# ─── US Market Data (Twelve Data) ─────────────────────────────────────────────
# Sign up at https://twelvedata.com to get your free API key
NEXT_PUBLIC_TWELVEDATA_API_KEY="your-twelvedata-api-key"

# ─── Stock Fundamentals (Alpha Vantage) ───────────────────────────────────────
# Sign up at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY="your-alphavantage-api-key"

# ─── AI Chat Assistant (OpenAI) ───────────────────────────────────────────────
# Sign up at https://platform.openai.com to get your API key
OPENAI_API_KEY="sk-your-openai-api-key"

# ─── News API ─────────────────────────────────────────────────────────────────
# Optional: Sign up at https://newsapi.org to enable news-driven AI context
NEWS_API_KEY="your-newsapi-key"

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# ─── Email Alerts (Gmail SMTP) ────────────────────────────────────────────────
# Used to send target price and 52-week high/low stock alert emails to users.
# Generate a Gmail App Password at: myaccount.google.com → Security → 2-Step Verification → App passwords
EMAIL_USER="your_gmail@gmail.com"
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# ─── Cron Secret (for /api/alerts/check) ──────────────────────────────────────
# Protects the price-alert cron job from unauthorized pings
# Can be any random string (e.g. openssl rand -hex 32)
CRON_SECRET="your-cron-secret"

# ─── Internal Alert Key ───────────────────────────────────────────────────────
# Shared secret between the WebSocket server and the alerts check API
ALERT_API_KEY="internal-alert-key"

# ─── App URL ─────────────────────────────────────────────────────────────────
# Base URL of the Next.js app (used by the WebSocket server to call the alerts API)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
